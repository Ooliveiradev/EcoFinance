# =============================================================================
# EcoFinance — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA faça commit do arquivo .env no controle de versão.
#
# Variáveis OBRIGATÓRIAS para rodar o dashboard localmente:
#   DATABASE_URL, GEMINI_API_KEY
#
# As demais são necessárias apenas para funcionalidades específicas
# (Pluggy Open Finance, app mobile, Supabase em produção).
# =============================================================================

# --- Banco de Dados (PostgreSQL) ---------------------------------------------
# Para uso local com Docker: postgresql://postgres:postgres@localhost:5432/ecofinance
# Para Supabase: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecofinance"

# --- Google Gemini AI --------------------------------------------------------
# Chave de API gratuita em: https://aistudio.google.com/app/apikey
# Usada para categorização de transações e chat financeiro
GEMINI_API_KEY="sua-chave-gemini-aqui"

# --- Pluggy Open Finance API (Opcional) --------------------------------------
# Necessário apenas para sincronização automática de bancos brasileiros
# Obtenha suas credenciais em: https://dashboard.pluggy.ai
PLUGGY_CLIENT_ID="seu-pluggy-client-id"
PLUGGY_CLIENT_SECRET="seu-pluggy-client-secret"

# --- Segurança da API Interna ------------------------------------------------
# Chave compartilhada entre o servidor Next.js e o app mobile
# Use qualquer string aleatória com pelo menos 32 caracteres
# Geração sugerida: openssl rand -hex 32
API_SECRET_KEY="sua-chave-secreta-minimo-32-caracteres"

# --- Supabase (Opcional — para produção) ------------------------------------
# Necessário apenas se usar Supabase como banco em produção (não precisa para Docker local)
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Variáveis públicas expostas ao browser (mesmo valor das acima)
NEXT_PUBLIC_SUPABASE_URL="https://seu-projeto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# --- App Mobile (Expo) -------------------------------------------------------
# Endereço do servidor Next.js acessível pelo celular/emulador
# No emulador Android: http://10.0.2.2:3000
# No celular físico: http://SEU_IP_LOCAL:3000 (ex: http://192.168.1.10:3000)
EXPO_PUBLIC_API_URL="http://10.0.2.2:3000"
EXPO_PUBLIC_API_SECRET="mesma-chave-do-API_SECRET_KEY-acima"
