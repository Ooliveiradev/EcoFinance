# =============================================================================
# EcoFinance Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Database (Supabase PostgreSQL) ---
# Direct connection string to the Supabase PostgreSQL database.
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/ecofinance"

# --- Supabase ---
# Supabase project URL (found in Project Settings > API)
SUPABASE_URL="https://your-project.supabase.co"

# Supabase anonymous (public) key — safe to expose in client-side code
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Supabase service role key — KEEP SECRET, only use server-side
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# --- Pluggy Open Finance API ---
# Client credentials from the Pluggy dashboard (https://dashboard.pluggy.ai)
PLUGGY_CLIENT_ID="your-pluggy-client-id"
PLUGGY_CLIENT_SECRET="your-pluggy-client-secret"

# --- Google Gemini AI ---
# API key for Gemini (used for transaction categorization and Uber receipt parsing)
GEMINI_API_KEY="your-gemini-api-key"

# --- Internal API Security ---
# Shared secret key used to authenticate webhook requests between services
API_SECRET_KEY="your-random-secret-key-min-32-chars"

# --- Public Client-Side Variables (Next.js) ---
# These are exposed to the browser — only use non-sensitive values
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
